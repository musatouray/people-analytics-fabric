	/// SVG chip badge highlighting the customer segment. Requires Image URL data category. Uses Bacci.SVG.Chip UDF.
	measure 'Customer Segment Chip' =
			
			VAR _segment = SELECTEDVALUE(FactCustomerRFM[Segment])
			VAR _colour =
			    SWITCH(
			        _segment,
			        "Champions",  "green",
			        "VIPs",       "amber",
			        "Loyalists",  "blue",
			        "At Risk",    "red",
			        "grey"
			    )
			RETURN
			    IF(
			        NOT ISBLANK(_segment),
			        Bacci.SVG.Chip(_segment, _colour)
			    )
		formatString: @
		displayFolder: SVG Visuals
		lineageTag: 7205592b-7cb8-4554-86ba-85e7563f84fb
		dataCategory: ImageUrl

	/// Total revenue from internet sales transactions
	measure 'Fact Revenue' = SUM(FactInternetSales[SalesAmount])
		formatString: $#,##0.00
		displayFolder: Fact Sales Performance
		lineageTag: 54b066f2-687e-4662-abcf-2b7a9416db43

	/// Distinct order count from internet sales transactions
	measure 'Fact Orders' = DISTINCTCOUNT(FactInternetSales[SalesOrderNumber])
		formatString: #,0
		displayFolder: Fact Sales Performance
		lineageTag: e1f24d2e-e369-4806-b282-6638eaec9e31

	/// Gross profit from internet sales (SalesAmount minus TotalProductCost)
	measure 'Fact Profit' = [Fact Revenue] - SUM(FactInternetSales[TotalProductCost])
		formatString: $#,##0.00
		displayFolder: Fact Sales Performance
		lineageTag: 992a10e7-5858-461a-9c45-48154a79e2b4

	/// Reads the Metric Selector slicer and returns IS Orders, IS Revenue or IS Profit accordingly. Use this measure in all visuals.
	measure 'Fact Selected Metric' = ```
			
			
			VAR _selectedValue = 
			    SELECTCOLUMNS(
			        SUMMARIZE(
			            'Param: Fact Metrics', 
			            'Param: Fact Metrics'[Param: Fact Metrics], 
			            'Param: Fact Metrics'[Param: Fact Metrics Fields], 
			            'Param: Fact Metrics'[Param: Fact Metrics Order]
			        ),
			        'Param: Fact Metrics'[Param: Fact Metrics]
			    )
			
			RETURN
			    IF (
			        COUNTROWS(_selectedValue) = 1,
			        SWITCH(
			            _selectedValue,
			            "Orders", [Fact Orders],
			            "Revenue", [Fact Revenue],
			            "Profit", [Fact Profit],
			            [Fact Revenue]
			        )
			    )
			
			```
		displayFolder: Fact Sales Performance
		lineageTag: ce4f5dbb-a79e-4ba3-aa00-7d228e65dbb0

		formatStringDefinition = ```
				VAR _selectedValue = 
				    SELECTCOLUMNS(
				        SUMMARIZE(
				            'Param: Fact Metrics', 
				            'Param: Fact Metrics'[Param: Fact Metrics], 
				            'Param: Fact Metrics'[Param: Fact Metrics Fields], 
				            'Param: Fact Metrics'[Param: Fact Metrics Order]
				        ),
				        'Param: Fact Metrics'[Param: Fact Metrics]
				    )
				
				RETURN
				    IF (
				        COUNTROWS(_selectedValue) = 1,
				        SWITCH(
				            _selectedValue,
				            "Orders",  "#,0",
				            "Revenue", "$#,##0.00",
				            "Profit",  "$#,##0.00",
				            "$#,##0.00"
				        )
				    )
				
				    
				```

	/// Dynamic title that updates to show which metric is currently selected (Orders / Revenue / Profit).
	measure 'Title Selected Metric' = ```
			
			VAR __SelectedMetric = SELECTEDVALUE('RFM Metric Selector'[Metric])
			VAR __SelectedYear = SELECTEDVALUE(DimDate[CalendarYear])
			VAR __MeasureValue = CALCULATE( SELECTEDMEASURE(), ALLSELECTED() )
			VAR __FormattedMeasure =
			   SWITCH(
			       TRUE(),
			       __MeasureValue <= 1E3, FORMAT(__MeasureValue, "#,0.00 K"),
			       __MeasureValue <= 1E6, FORMAT(__MeasureValue, "#,0,.00 K"),
			       __MeasureValue <= 1E9, FORMAT(__MeasureValue, "#,0,,.00 M"),
			       __MeasureValue <= 1E12, FORMAT(__MeasureValue, "#,0,,,.00 B")
			   )
			
			RETURN
			SWITCH(
			    __SelectedMetric,
			    "Orders", "Total Orders in " & __SelectedYear & " is " & __FormattedMeasure,
			    "Revenue", "Total Revenue in " & __SelectedYear & " is " & __FormattedMeasure,
			    "Profit", "Total Profit in " & __SelectedYear & " is " & __FormattedMeasure
			)
			
			```
		displayFolder: RFM\Sales Health
		lineageTag: 3cc27484-c280-4580-85f1-845a9cf44bba

	/// Bridge measure: filters [Selected Metric] by the current FactCustomerRFM[Segment] filter context. Use as salesByProductGroupMeasure in ColumnChart.Stacked.
	measure 'RFM Metric by Segment' =
			
			VAR _SegmentCustomers = VALUES(FactCustomerRFM[CustomerKey])
			RETURN
			    CALCULATE(
			        [Selected Metric (Orders, Rev, Profit)],
			        TREATAS(_SegmentCustomers, DimCustomer[CustomerKey])
			    )
		displayFolder: RFM\Sales Health
		lineageTag: 95373000-e27d-4b92-91d8-939ce52d3630

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// Absolute change in [Selected Metric] vs same period previous year.
	measure 'IS Change PY' =
			
			VAR _AC = [Fact Selected Metric]
			VAR _PY = CALCULATE([Fact Selected Metric], SAMEPERIODLASTYEAR(DimDate[FullDateAlternateKey]))
			RETURN
			    IF(NOT ISBLANK(_PY), _AC - _PY)
		displayFolder: Fact Sales Performance
		lineageTag: 69d15d4b-e36e-4916-8ccf-3ba6f74cc8f4

		formatStringDefinition =
				VAR _s = SELECTEDVALUE('RFM Metric Selector'[Metric])
				RETURN SWITCH(_s, "Orders", "+#,0;-#,0;0", "+$#,##0.00;-$#,##0.00;0")

	/// Relative change (%) in [Selected Metric] vs same period previous year.
	measure 'IS Change PY %' =
			
			VAR _AC = [Fact Selected Metric]
			VAR _PY = CALCULATE([Fact Selected Metric], SAMEPERIODLASTYEAR(DimDate[FullDateAlternateKey]))
			RETURN
			    IF(NOT ISBLANK(_PY), DIVIDE(_AC - _PY, ABS(_PY)))
		formatString: +0.0%;-0.0%;0%
		displayFolder: Fact Sales Performance
		lineageTag: 331fad7d-7e8a-403f-968f-6fe3abf6cd90

	/// IBCS vertical column chart showing [Selected Metric] AC (black) vs PY (grey) with red/green variance bar per period. Place DimDate[FullDateAlternateKey] in matrix columns. businessImpact=1 means higher is better.
	measure 'IBCS Variance Column' =
			PowerofBI.IBCS.ColumnChart.WithAbsoluteVariance(
			    [Fact Selected Metric],
			    CALCULATE([Fact Selected Metric], SAMEPERIODLASTYEAR(DimDate[FullDateAlternateKey])),
			    BLANK(),
			    BLANK(),
			    DimDate[CalendarYear],
			    1)
		formatString: @
		displayFolder: SVG Visuals
		lineageTag: 0bf23d3d-bb46-41ac-a644-512cf5870bf3
		dataCategory: ImageUrl

	/// IBCS horizontal bar chart: black bar = AC, grey bar = PY. Scale is relative to the max across all visible segments. DataCategory = ImageUrl.
	measure 'IBCS Bar AbsoluteValues' =
			VAR _PY = CALCULATE([RFM Metric by Segment], SAMEPERIODLASTYEAR(DimDate[FullDateAlternateKey]))
			VAR _FmtLabel = SWITCH(SELECTEDVALUE('RFM Metric Selector'[Metric]), "Orders", "#,0", "Revenue", "$#,##0", "Profit", "$#,##0", "$#,##0")
			RETURN
			PowerofBI.IBCS.BarChart.AbsoluteValues(
			    FactCustomerRFM[Segment],
			    [RFM Metric by Segment],
			    BLANK(),
			    _PY,
			    [RFM Metric by Segment],
			    "grey",
			    NOT ISINSCOPE(FactCustomerRFM[Segment]),
			    FORMAT([RFM Metric by Segment], _FmtLabel),
			    200,
			    35)
		formatString: @
		displayFolder: SVG Visuals
		lineageTag: 15c14af5-c7da-4596-966b-cff853e85ec2
		dataCategory: ImageUrl

	/// IBCS horizontal bar chart showing AC vs PY bars plus a small green/red absolute variance bar. Green = favorable, red = unfavorable. DataCategory = ImageUrl.
	measure 'IBCS Bar AbsoluteVariance' =
			VAR _AC = [RFM Metric by Segment]
			VAR _PY = CALCULATE([RFM Metric by Segment], SAMEPERIODLASTYEAR(DimDate[FullDateAlternateKey]))
			VAR _FmtLabel = SWITCH(SELECTEDVALUE('RFM Metric Selector'[Metric]), "Orders", "+#,0;-#,0;=", "Revenue", "+$#,##0;-$#,##0;=", "Profit", "+$#,##0;-$#,##0;=", "+$#,##0;-$#,##0;=")
			RETURN
			PowerofBI.IBCS.BarChart.AbsoluteVariance(
			    FactCustomerRFM[Segment],
			    _AC,
			    BLANK(),
			    _PY,
			    [RFM Metric by Segment],
			    "grey",
			    NOT ISINSCOPE(FactCustomerRFM[Segment]),
			    FORMAT(_AC - _PY, _FmtLabel),
			    200,
			    35,
			    1)
		formatString: @
		displayFolder: SVG Visuals
		lineageTag: 9ca87a0e-abaa-4b17-8c8c-139f9cbcea1f
		dataCategory: ImageUrl

	/// IBCS pin chart showing % variance vs PY on a centered zero baseline. Pin length = magnitude, green/red = direction. DataCategory = ImageUrl.
	measure 'IBCS Bar RelativeVariance' =
			VAR _AC = [RFM Metric by Segment]
			VAR _PY = CALCULATE([RFM Metric by Segment], SAMEPERIODLASTYEAR(DimDate[FullDateAlternateKey]))
			RETURN
			PowerofBI.IBCS.BarChart.RelativeVariance(
			    FactCustomerRFM[Segment],
			    _AC,
			    BLANK(),
			    _PY,
			    "grey",
			    NOT ISINSCOPE(FactCustomerRFM[Segment]),
			    FORMAT(DIVIDE(_AC - _PY, ABS(_PY)) * 100, "+#,0.0;-#,0.0;=" ) & "%",
			    200,
			    35,
			    1)
		formatString: @
		displayFolder: SVG Visuals
		lineageTag: 96c4cb32-d250-4524-8574-846103ed7295
		dataCategory: ImageUrl

	/// Gross profit as a % of internet sales revenue. Higher is better.
	measure 'Fact Gross Margin %' = DIVIDE([Fact Profit], [Fact Revenue])
		formatString: +0.0%;-0.0%;0.0%
		displayFolder: Fact Sales Performance
		lineageTag: 5d68a037-fbb3-4b22-8c90-6db026bede6e

	/// Average revenue per internet sales order (IS Revenue ÷ IS Orders).
	measure 'IS Avg Order Value' = DIVIDE([Fact Revenue], [Fact Orders])
		formatString: $#,##0.00
		displayFolder: Fact Sales Performance
		lineageTag: fb2699c2-c589-4515-94f5-dd3190678ee2

	/// Total discount dollars applied across all internet sales order lines.
	measure 'IS Discount Amount' = SUM(FactInternetSales[DiscountAmount])
		formatString: $#,##0.00
		displayFolder: Promotion Analysis
		lineageTag: 07c88844-3a68-4066-9103-b1362933f32a

	/// Average unit price discount % across all sales order lines.
	measure 'IS Avg Discount %' = AVERAGE(FactInternetSales[UnitPriceDiscountPct])
		formatString: 0.00%
		displayFolder: Promotion Analysis
		lineageTag: ef50bb47-9a58-4f80-a730-6866d24a3048

	/// Revenue from orders that had an active promotion applied (excluding No Discount rows).
	measure 'IS Promo Revenue' = CALCULATE([Fact Revenue], DimPromotion[EnglishPromotionName] <> "No Discount")
		formatString: $#,##0.00
		displayFolder: Promotion Analysis
		lineageTag: d029d5bb-d50d-4974-b315-f085552b5d3e

	/// Revenue from orders with no promotion applied (baseline / organic revenue).
	measure 'IS No Promo Revenue' = CALCULATE([Fact Revenue], DimPromotion[EnglishPromotionName] = "No Discount")
		formatString: $#,##0.00
		displayFolder: Promotion Analysis
		lineageTag: 48f31828-9066-4cc6-ac27-cb1246ec99e8

	/// Discount dollars as a % of gross revenue. Shows how much revenue was given away as discounts.
	measure 'IS Discount % of Revenue' = DIVIDE([IS Discount Amount], [Fact Revenue])
		formatString: 0.00%
		displayFolder: Promotion Analysis
		lineageTag: f5a9544b-3356-400d-9878-934a537f57a4

	/// Average days since last order across customers in the current filter context. Lower = more recent.
	measure 'RFM Avg Recency' = AVERAGE(FactCustomerRFM[Recency])
		formatString: #,0
		displayFolder: RFM\Grow and Risk
		lineageTag: 47a60c5c-4bc1-407e-bff7-317596f2a835

	/// Average number of orders per customer in the current filter context. Higher = more loyal.
	measure 'RFM Avg Frequency' = AVERAGE(FactCustomerRFM[Frequency])
		formatString: 0.0
		displayFolder: RFM\Grow and Risk
		lineageTag: dba2a318-58f0-4561-b5ab-5fa9a58bc36f

	/// Segment share of total revenue. Sums to 100% across all segments.
	measure 'RFM Revenue Share %' = DIVIDE([Total Revenue], CALCULATE([Total Revenue], ALL(FactCustomerRFM[Segment])))
		formatString: 0.0%
		displayFolder: RFM\Grow and Risk
		lineageTag: 080193b1-a092-48f7-8cf0-9fb22aa83c72

	/// Territory's share of total internet sales revenue across all territories.
	measure 'IS Revenue Territory %' =
			
			DIVIDE([Fact Revenue], CALCULATE([Fact Revenue], ALL(DimSalesTerritory[SalesTerritoryGroup], DimSalesTerritory[SalesTerritoryCountry], DimSalesTerritory[SalesTerritoryRegion])))
		formatString: 0.0%
		displayFolder: Fact Sales Performance
		lineageTag: 297d96c0-b139-49d8-a39a-da9e862604b1

	measure 'Selected Metric (Orders, Rev, Profit)' =
			
			VAR _selected = SELECTEDVALUE('RFM Metric Selector'[Metric])
			RETURN
			    SWITCH(
			        _selected,
			        "Orders",  CALCULATE([Total Orders]),
			        "Revenue", CALCULATE([Total Revenue]),
			        "Profit",  CALCULATE([Total Profit]),
			        CALCULATE([Total Revenue])
			    )
		displayFolder: RFM\Sales Health
		lineageTag: b150a570-d5b3-4014-9fb1-7724a4250826

		formatStringDefinition = ```
				VAR __selectedMetric = SELECTEDVALUE('RFM Metric Selector'[Metric])
				VAR __val = [Selected Metric (Orders, Rev, Profit)]
				RETURN
				SWITCH(
				    TRUE(),
				    __val <= 1E3, "#,0",
				    __selectedMetric = "Orders" && __val <= 1E3, "#,0",
				    __selectedMetric in {"Revenue", "Profit"} && __val <= 1E6, "#,0,.00 K",
				    __selectedMetric in {"Revenue", "Profit"} && __val <= 1E9, "#,0,,.00 M",
				    __selectedMetric in {"Revenue", "Profit"} && __val <= 1E12, "#,0,,,.00 B"
				)
				
				```

	measure 'Top N Filter' = ```
			
			VAR _SelectedMetric = [Fact Selected Metric] 
			VAR _TopN = [Top N Value]
			VAR _Direction = SELECTEDVALUE('TopBottomSelector'[Direction], "DESC")
			
			-- Use ALLSELECTED to break the row context of the visual
			VAR _Rank = 
			    IF(
			        NOT ISBLANK(_SelectedMetric),
			        IF(
			            _Direction = "ASC",
			            RANKX(
			                ALLSELECTED(DimProduct[EnglishProductName]),
			                CALCULATE([Fact Selected Metric], ALLSELECTED(DimProduct[EnglishProductName])),
			                ,
			                ASC,
			                Dense
			            ),
			            RANKX(
			                ALLSELECTED(DimProduct[EnglishProductName]),
			                CALCULATE([Fact Selected Metric], ALLSELECTED(DimProduct[EnglishProductName])),
			                ,
			                DESC,
			                Dense
			            )
			        )
			    )
			
			RETURN
			   IF(NOT ISBLANK(_Rank) && _Rank <= _TopN, 1, 0)
			
			```
		displayFolder: Fact Sales Performance
		lineageTag: dba1a177-1c07-48fa-8b36-97ca602abd96

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Color Selected Segment' = ```
			
			VAR __SelectedSegment = SELECTEDVALUE(FactCustomerRFM[Segment])
			RETURN
			SWITCH(
			    __SelectedSegment,
			    "Champions", "#e6f4ea",
			    "VIPs", "#fff4e5",
			    "Loyalists", "#ebf2ff",
			    "At RisK", "#f5d4df"
			)
			
			```
		displayFolder: RFM\Sales Health
		lineageTag: fddadac2-ce3e-4447-92d6-63dfa9d1250c

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	/// KPI card for total orders — inline SVG foreignObject, no UDF call.
	/// SVG KPI card for total orders — rendered via SVG.HtmlCard UDF.
	measure 'HTML Card Total Orders' =
			VAR _current = [Total Orders]
			VAR _py = [Total Orders PY]
			VAR _yoyPct = [Total Orders YOY %]
			VAR _subtitle = "Year " & COALESCE(FORMAT(SELECTEDVALUE(DimDate[CalendarYear]), "0"), "YTD")
			VAR _bulletHtml = CONCATENATEX(ADDCOLUMNS(TOPN(3, VALUES(DimProductSubcategory[EnglishProductSubcategoryName]), CALCULATE([Total Orders]), DESC), "@pct", DIVIDE(CALCULATE([Total Orders]), [Total Orders])), "<li><span class='bn'>" & DimProductSubcategory[EnglishProductSubcategoryName] & "</span><span class='bp'>" & FORMAT([@pct], "0.0%") & "</span></li>", "", [@pct], DESC)
			RETURN
			    SVG.HtmlCard(
			        FORMAT(_current, "#,##0"),
			        FORMAT(_py, "#,##0"),
			        FORMAT(_yoyPct, "+0.0%;-0.0%;0.0%"),
			        "Total Orders",
			        _subtitle,
			        "orders",
			        _bulletHtml
			    )
		formatString: @
		displayFolder: HTML Cards
		lineageTag: 29a9770f-a174-4d5b-9b98-bb2d2f3f78a0
		dataCategory: ImageUrl


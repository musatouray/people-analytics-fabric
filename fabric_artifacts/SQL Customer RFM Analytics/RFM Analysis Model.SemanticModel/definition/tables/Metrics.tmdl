	/// Customer count change vs same period last year (absolute Δ).
	measure 'Total Customers YOY Δ' = [Total Customers] - [Total Customers PY]
		formatString: #,0
		displayFolder: Time Intelligence\Grow and Risk\Period Change
		lineageTag: 9e61c8ce-9457-433a-b1f1-a7f8fb5b7698

	/// Churned customer count change vs previous month (absolute Δ).

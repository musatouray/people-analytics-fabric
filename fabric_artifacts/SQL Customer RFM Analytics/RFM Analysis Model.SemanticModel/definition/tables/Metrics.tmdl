	/// Fact Selected Metric in the same period last year — follows the active Fact Metric Selector choice.
	/// Uses CALCULATE with ALL('Fact Metric Selector') to escape the calculation group override.
	/// Use this as the PY series on the column chart — NOT [Fact Revenue PY] directly.
	measure 'Fact Selected Metric PY' = ```
			
			
			VAR _selectedValue = 
			    SELECTCOLUMNS(
			        SUMMARIZE(
			            'Param: Fact Metrics', 
			            'Param: Fact Metrics'[Param: Fact Metrics], 
			            'Param: Fact Metrics'[Param: Fact Metrics Fields], 
			            'Param: Fact Metrics'[Param: Fact Metrics Order]
			        ),
			        'Param: Fact Metrics'[Param: Fact Metrics]
			    )
			
			RETURN
			    IF (
			        COUNTROWS(_selectedValue) = 1,
			        SWITCH(
			            _selectedValue,
			            "Orders", [Fact Orders PY],
			            "Revenue", [Fact Revenue PY],
			            "Profit", [Fact Profit PY],
			            [Fact Revenue PY]
			        )
			    )
			
			```
		displayFolder: Fact Time Intelligence
		lineageTag: d2e3f4a5-b6c7-4d8e-9f01-112233445502

		formatStringDefinition = ```

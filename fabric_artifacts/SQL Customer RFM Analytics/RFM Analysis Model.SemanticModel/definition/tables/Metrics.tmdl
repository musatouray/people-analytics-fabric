			VAR _py = [Total Customers PY]
			VAR _yoyPct = [Total Customers YOY %]
			VAR _subtitle = "Year " & COALESCE(FORMAT(SELECTEDVALUE(DimDate[CalendarYear]), "0"), "YTD")
			VAR _bulletHtml = CONCATENATEX(ADDCOLUMNS(TOPN(3, VALUES(DimCustomer[CustomerKey]), CALCULATE([Fact Revenue]), DESC), "@nm", CALCULATE(MAX(DimCustomer[FirstName]) & " " & MAX(DimCustomer[LastName])), "@pct", DIVIDE(CALCULATE([Fact Revenue]), [Fact Revenue])), "<li><span class='bn'>" & [@nm] & "</span><span class='bp'>" & FORMAT([@pct], "0.0%") & "</span></li>", "", [@pct], DESC)
			RETURN
			    SVG.HtmlCard(
			        FORMAT(_current, "#,##0"),

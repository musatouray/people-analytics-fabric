		lineageTag: c1d2e3f4-a5b6-4c7d-8e9f-001122334402

	/// Fact Revenue month-over-month change (absolute Δ).
	measure 'Fact Revenue MOM Δ' = [Fact Revenue] - [Fact Revenue PM]

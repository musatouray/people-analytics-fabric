	/// SVG KPI card for the dynamically selected Fact metric (Orders / Revenue / Profit) — changes with the Fact Metric Selector slicer.
	measure 'HTML Card Fact Selected' =
			VAR _selected = SELECTEDVALUE('Fact Metric Selector'[Metric])
			VAR _current = [Fact Selected Metric]
			VAR _py = [Fact Selected Metric PY]
			VAR _yoyPct = [Fact Selected Metric YOY %]
			VAR _subtitle = "Year " & COALESCE(FORMAT(SELECTEDVALUE(DimDate[CalendarYear]), "0"), "YTD")
			VAR _title = SWITCH(_selected, "Orders", "Total Orders", "Revenue", "Total Revenue", "Profit", "Total Profit", "Total Revenue")
			VAR _icon = SWITCH(_selected, "Orders", "orders", "Revenue", "revenue", "Profit", "profit", "revenue")
			VAR _currentFmt = SWITCH(_selected, "Orders", FORMAT(_current, "#,##0"), "$" & FORMAT(_current, "#,##0"))
			VAR _pyFmt = SWITCH(_selected, "Orders", FORMAT(_py, "#,##0"), "$" & FORMAT(_py, "#,##0"))
			VAR _sel = SELECTEDVALUE('Fact Metric Selector'[Metric], "Revenue")
			VAR _totalSel = IF(_sel = "Orders", [Fact Orders], IF(_sel = "Profit", [Fact Profit], [Fact Revenue]))
			VAR _bulletHtml = CONCATENATEX(ADDCOLUMNS(TOPN(3, VALUES(DimProductSubcategory[EnglishProductSubcategoryName]), IF(_sel = "Orders", CALCULATE([Fact Orders]), IF(_sel = "Profit", CALCULATE([Fact Profit]), CALCULATE([Fact Revenue]))), DESC), "@pct", DIVIDE(IF(_sel = "Orders", CALCULATE([Fact Orders]), IF(_sel = "Profit", CALCULATE([Fact Profit]), CALCULATE([Fact Revenue]))), _totalSel)), "<li><span class='bn'>" & DimProductSubcategory[EnglishProductSubcategoryName] & "</span><span class='bp'>" & FORMAT([@pct], "0.0%") & "</span></li>", "", [@pct], DESC)
			RETURN
			    SVG.HtmlCard(
			        _currentFmt,
			        _pyFmt,
			        FORMAT(_yoyPct, "+0.0%;-0.0%;0.0%"),
			        _title,
			        _subtitle,
			        _icon,
			        _bulletHtml
			    )
		formatString: @
		displayFolder: Fact HTML Cards
		lineageTag: f1a2b3c4-d5e6-4f70-8192-a3b4c5d6e704
		dataCategory: ImageUrl

	/// SVG KPI card for Fact Gross Margin % — rendered via SVG.HtmlCard UDF.
	measure 'HTML Card Fact Gross Margin' =
			VAR _current = [Fact Gross Margin %]
			VAR _py = [Fact Gross Margin % PY]
			VAR _yoyAbs = _current - _py
			VAR _subtitle = "Year " & COALESCE(FORMAT(SELECTEDVALUE(DimDate[CalendarYear]), "0"), "YTD")
			VAR _bulletHtml = CONCATENATEX(ADDCOLUMNS(TOPN(3, VALUES(DimProductSubcategory[EnglishProductSubcategoryName]), CALCULATE([Fact Profit]), DESC), "@pct", DIVIDE(CALCULATE([Fact Profit]), [Fact Profit])), "<li><span class='bn'>" & DimProductSubcategory[EnglishProductSubcategoryName] & "</span><span class='bp'>" & FORMAT([@pct], "0.0%") & "</span></li>", "", [@pct], DESC)
			RETURN
			    SVG.HtmlCard(
			        FORMAT(_current, "+0.0%;-0.0%;0.0%"),
			        FORMAT(_py, "+0.0%;-0.0%;0.0%"),
			        FORMAT(_yoyAbs, "+0.0pp;-0.0pp;0.0pp"),
			        "Profit Margin",
			        _subtitle,
			        "margin",
			        _bulletHtml
			    )
		formatString: @
		displayFolder: Fact HTML Cards
		lineageTag: f1a2b3c4-d5e6-4f70-8192-a3b4c5d6e705
		dataCategory: ImageUrl

	column Column
		isHidden
		formatString: 0
		lineageTag: 11d94115-b4d5-4fdf-b86f-d9373e72e24b
		summarizeBy: sum
		isNameInferred
		sourceColumn: [Column]

		annotation SummarizationSetBy = Automatic

	partition Metrics = calculated
		mode: import
		source = Row("Column", BLANK())


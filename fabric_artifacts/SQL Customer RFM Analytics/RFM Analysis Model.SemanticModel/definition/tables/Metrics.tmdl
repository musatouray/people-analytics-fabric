	measure 'Total Customers PM' = CALCULATE([Total Customers], DATEADD('DimDate'[FullDateAlternateKey], -1, MONTH))
		formatString: #,0
		displayFolder: Time Intelligence\Grow and Risk\Previous Period
		lineageTag: 04723e87-e1d3-4b08-b93b-da434fd229e7

	/// Total Customers in the same period last year.
	measure 'Total Customers PY' = CALCULATE([Total Customers], DATEADD('DimDate'[FullDateAlternateKey], -1, YEAR))

	/// IBCS stacked column chart showing Champions/VIPs/Loyalists/At Risk segment contributions per period. Place DimDate[FullDateAlternateKey] in matrix columns. Set visual image size in Format pane. Use Segment Slicer to highlight a segment.
	measure 'IBCS Segment Stacked' =
			
			PowerofBI.IBCS.ColumnChart.Stacked(
			    [IS Metric by Segment],
			    FactCustomerRFM[Segment],
			    'Segment Slicer'[Segment],
			    DimDate[FullDateAlternateKey],
			    0,
			    0
			)
		formatString: @

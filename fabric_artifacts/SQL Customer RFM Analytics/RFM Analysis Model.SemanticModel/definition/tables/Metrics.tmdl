/// Virtual table that holds all DAX measures. No data rows — only used to organise measures in the field list.
table Metrics
	lineageTag: 1a487961-fb03-477f-afbc-73197a0e69dd

	/// Total sales amount across all internet orders. Sum of FactInternetSales[SalesAmount].
	measure 'Total Revenue' = SUM(FactCustomerRFM[Monetary])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: RFM\Sales Health
		lineageTag: 46c32a7b-11ca-4765-bcbb-a7aac8495d97

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Number of distinct sales orders placed.
	measure 'Total Orders' = SUM(FactCustomerRFM[Frequency])
		formatString: #,0
		displayFolder: RFM\Sales Health
		lineageTag: 3e770b6b-ad71-4521-8795-18c11cc7f9fb

	/// Average value per order (Total Revenue ÷ Total Orders).
	measure 'Avg Order Value' = DIVIDE([Total Revenue], [Total Orders])
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: RFM\Sales Health
		lineageTag: 02cafbb9-bc8b-4960-8cd6-a42d6f2cbdc6

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Number of distinct customers who placed at least one order.
	measure 'Total Customers' = DISTINCTCOUNT(FactCustomerRFM[CustomerKey])
		formatString: #,0
		displayFolder: RFM\Sales Health
		lineageTag: 42fbd993-5768-4a8e-b776-d241a37ec6b6

	/// Customers who bought in a prior period but have not bought in the current period.
	measure 'Churned Customers' = ```
			
			VAR __ChurnCutOff = 180
			RETURN
			CALCULATE(
			    [Total Transactions], 
			    FactCustomerRFM[Recency] > __ChurnCutOff
			)
			
			```
		formatString: #,0
		displayFolder: RFM\Grow and Risk
		lineageTag: de6239c2-987b-4d63-9524-d228c9062e3d

	/// Total number of individual order line transactions.
	measure 'Total Transactions' = COUNTROWS(FactCustomerRFM)
		formatString: #,0
		displayFolder: RFM\Sales Health
		lineageTag: 204e898a-68dc-4386-9ca9-15b9ba4c7127

	/// Churned Customers as a % of Total Customers. Tracks how much of the customer base was lost.
	measure 'Churn Rate %' =
			
			DIVIDE([Churned Customers], [Total Transactions])
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: RFM\Grow and Risk
		lineageTag: 9ce57603-6f85-4374-bf33-f62004971715

	/// Total cost of goods sold across all orders.
	measure 'Total Cost' = ```
			SUM(FactCustomerRFM[TotalCost])
			
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: RFM\Sales Health
		lineageTag: cb0303ab-8f4d-4f68-92c3-0c1c9e816da6

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Gross profit: Total Revenue minus Total Cost.
	measure 'Total Profit' = ```
			SUM(FactCustomerRFM[Profit])
			
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: RFM\Sales Health
		lineageTag: c6f1ab40-e8a0-4e2a-886a-a2dd6c06f553

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	/// Total Revenue in the previous month.
	measure 'Total Revenue PM' = CALCULATE([Total Revenue], DATEADD('DimDate'[FullDateAlternateKey], -1, MONTH))
		formatString: #,0
		displayFolder: Time Intelligence\Sales Health\Previous Period
		lineageTag: 3b48c465-4bc3-4b76-880c-319c011e5c3f

	/// Total Revenue in the same period last year.
	measure 'Total Revenue PY' = CALCULATE([Total Revenue], DATEADD('DimDate'[FullDateAlternateKey], -1, YEAR))
		formatString: #,0
		displayFolder: Time Intelligence\Sales Health\Previous Period
		lineageTag: c11c8a3c-c438-4a21-8947-5a85305b3104

	/// Total Orders in the previous month.
	measure 'Total Orders PM' = CALCULATE([Total Orders], DATEADD('DimDate'[FullDateAlternateKey], -1, MONTH))
		formatString: #,0
		displayFolder: Time Intelligence\Sales Health\Previous Period
		lineageTag: c47aceb3-8cd8-431b-a2d0-09bdc71722ef

	/// Total Orders in the same period last year.
	measure 'Total Orders PY' = CALCULATE([Total Orders], DATEADD('DimDate'[FullDateAlternateKey], -1, YEAR))

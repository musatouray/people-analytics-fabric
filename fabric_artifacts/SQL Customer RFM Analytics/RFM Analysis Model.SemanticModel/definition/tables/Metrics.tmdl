	/// Revenue change vs previous month (absolute Δ).
	measure 'Total Revenue MOM Δ' = [Total Revenue] - [Total Revenue PM]
		formatString: #,0
		displayFolder: Time Intelligence\Sales Health\Period Change
		lineageTag: 1f6a0f54-c1a8-4b6b-974b-d38da68ac3dd


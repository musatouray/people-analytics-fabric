	/// Fact Revenue in the previous month.
	measure 'Fact Revenue PM' = CALCULATE([Fact Revenue], DATEADD('DimDate'[FullDateAlternateKey], -1, MONTH))
		formatString: $#,##0.00
		displayFolder: Fact Time Intelligence
		lineageTag: c1d2e3f4-a5b6-4c7d-8e9f-001122334401

	/// Fact Revenue in the same period last year.
	measure 'Fact Revenue PY' = CALCULATE([Fact Revenue], DATEADD('DimDate'[FullDateAlternateKey], -1, YEAR))
		formatString: $#,##0.00
